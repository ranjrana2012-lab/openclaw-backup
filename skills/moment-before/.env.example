# OpenAI API Key for DALL-E image generation
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# TRMNL E-Ink Display Configuration
# Get yours from: https://usetrmnl.com
TRMNL_API_KEY=your-trmnl-api-key
TRMNL_DEVICE_ID=your-device-id

# Optional: Image hosting configuration
# For TRMNL push, you need a publicly accessible URL
# Configure your hosting service (S3, Cloudflare R2, etc.)
# IMAGE_HOSTING_URL=https://your-bucket.s3.amazonaws.com/
